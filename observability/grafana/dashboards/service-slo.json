{
  "title": "Demo API SLO Dashboard",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "rate(demo_api_requests_total[5m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(demo_api_errors_total[5m]) / clamp_min(rate(demo_api_requests_total[5m]), 0.001)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(demo_api_request_duration_seconds_bucket[5m]))"
        }
      ]
    }
  ]
}
